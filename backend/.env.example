# Server
PORT=3002
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_NAME=your_db_name
DB_PASSWORD=your_db_password
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_hex_secret

# API Keys — must be different values; generate with: node -e "console.log(require('crypto').randomUUID())"
CLIENT_API_KEY=replace_with_unique_client_key
ADMIN_API_KEY=replace_with_different_admin_key

# Email (Gmail example — use an App Password, not your account password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=your_email@gmail.com

# External client API
CLIENT_API_URL=http://localhost:3001/api/internal

# Seed (only used by prisma/seed.js — never used in production)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeThisPassword123
